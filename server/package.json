{
  "name": "grievance-management-server",
  "version": "1.0.0",
  "description": "Backend server for grievance management system",
  "main": "dist/config/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only config/server.ts",
    "build": "npm run prisma:generate && npx tsc",
    "start": "node dist/config/server.js",
    "prisma:generate": "npx prisma generate --schema=config/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=config/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=config/prisma/schema.prisma",
    "seed": "ts-node config/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.19.1",
    "@supabase/supabase-js": "^2.95.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "jsdom": "^28.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "prisma": "6.19.1",
    "typescript": "^5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.3",
    "@types/nodemailer": "^6.4.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "prisma": "6.19.1",
      "@prisma/client": "6.19.1"
    }
  },
  "resolutions": {
    "prisma": "6.19.1",
    "@prisma/client": "6.19.1"
  }
}
