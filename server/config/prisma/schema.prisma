// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// User accounts (students + admins)
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role
  studentId    String?    @unique
  department   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  petitions        Petition[]       @relation("StudentPetitions")
  assignedPetitions Petition[]      @relation("AssignedPetitions")
  comments          PetitionComment[]
  statusHistory     PetitionStatusHistory[]
  notifications     Notification[]
  auditLogs         AuditLog[]
}

// Main petition table
model Petition {
  id             String                @id @default(uuid())
  studentId      String
  student        User                  @relation("StudentPetitions", fields: [studentId], references: [id])
  studentName    String
  studentEmail   String
  department     String
  year           String
  type           PetitionType
  priority       Priority              @default(medium)
  subject        String
  description    String
  status         PetitionStatus        @default(submitted)
  assignedTo     String?               
  assignedUser   User?                 @relation("AssignedPetitions", fields: [assignedTo], references: [id])
  escalationLevel Int                  @default(1)
  submittedAt    DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  comments       PetitionComment[]
  attachments    PetitionAttachment[]
  statusHistory  PetitionStatusHistory[]
  notifications  Notification[]
}

// Petition comments
model PetitionComment {
  id         String   @id @default(uuid())
  petitionId String
  petition   Petition @relation(fields: [petitionId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  authorName String
  authorRole Role
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Petition attachments
model PetitionAttachment {
  id         String   @id @default(uuid())
  petitionId String
  petition   Petition @relation(fields: [petitionId], references: [id])
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())
}

// Petition status history
model PetitionStatusHistory {
  id             String          @id @default(uuid())
  petitionId     String
  petition       Petition        @relation(fields: [petitionId], references: [id])
  previousStatus PetitionStatus?
  newStatus      PetitionStatus
  changedBy      String
  changedUser    User            @relation(fields: [changedBy], references: [id])
  changedByName  String
  changedByRole  Role
  comment        String?
  changedAt      DateTime        @default(now())
}

// Notifications
model Notification {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  petitionId String?
  petition   Petition?   @relation(fields: [petitionId], references: [id])
  title     String
  message   String
  type      NotificationType @default(info)
  isRead    Boolean      @default(false)
  createdAt DateTime     @default(now())
}

// Audit logs
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  userName    String?
  userRole    Role?
  action      String
  resourceType String
  resourceId  String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// 🔹 Enums for better type-safety
enum Role {
  student
  class_advisor
  hod
  registrar
}

enum PetitionType {
  academic_issue
  administrative_issue
  facility_issue
  disciplinary_issue
  financial_issue
  other
}

enum PetitionStatus {
  submitted
  under_review
  forwarded_to_hod
  forwarded_to_registrar
  resolved
  rejected
}

enum Priority {
  low
  medium
  high
  urgent
}

enum NotificationType {
  info
  success
  warning
  error
}
