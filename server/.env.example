# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000

# Used to turn relative TenantSettings.logoUrl (e.g. /logo.png) into absolute URLs in emails.
# Should match your live Next.js origin (same as FRONTEND_URL if the logo is served from the app).
# FRONTEND_URL=https://your-portal.example.com
# EMAIL_ASSET_BASE_URL=https://your-portal.example.com

# School / thesis build: lock org settings & developer APIs. Pair with NEXT_PUBLIC_SCHOOL_BUILD on the Next app.
# SCHOOL_BUILD=true

# Student registration roster (name + Student ID + optional department). Empty JSON array [] disables checks.
# Default file: config/data/studentRoster.json (relative to server working directory).
# STUDENT_ROSTER_PATH=C:\path\to\custom-roster.json

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Access token lifetime (e.g. 8h, 24h, 7d). Default 8h — align with your session policy.
JWT_EXPIRES_IN=8h

# Supabase Database URLs
# Get these from: Supabase Dashboard → Settings → Database
# Replace [PASSWORD] with your database password
# Transaction pooler (port 6543) for the running app. Include pgbouncer=true for Prisma.
# If you see P2024 (pool timeout) or P1001 (can't reach DB): confirm project is not paused, then try appending:
#   &connection_limit=5&pool_timeout=30&connect_timeout=15
# Use a single API process locally so the pool is not exhausted across multiple servers.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Email Service Configuration (Optional — without it, new accounts are auto-verified for local demo)
#
# Option A — Resend (recommended for production)
# 1) Create API key at https://resend.com
# 2) Verify your sending domain and set RESEND_FROM_EMAIL to an address on that domain
#    (using onboarding@resend.dev only works to your own account email in trial)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=noreply@your-verified-domain.com
# RESEND_FROM_NAME=Grievance Portal
#
# Option B — SMTP (e.g. Gmail): Enable 2-Step Verification → App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="Grievance Management System <your-email@gmail.com>"

# If email is configured, users must verify before login unless you set:
# REQUIRE_EMAIL_VERIFICATION=false

